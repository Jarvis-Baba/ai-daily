{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "moduleResolution": "node10",
    "resolveJsonModule": true,
    "types": ["jest", "node"]
  },
  "include": ["./**/*.ts"]
}
